# Backend environment variables — copy to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# --- Claude API ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Clerk auth (backend) ---
CLERK_SECRET_KEY=

# --- Clerk auth (frontend publishable key) ---
# Also read by the backend: app/auth.py decodes this to derive the Clerk issuer
# and JWKS URL for JWT signature verification. Not a secret (client holds it too).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- Local infra (docker-compose: Postgres + Redis) ---
DATABASE_URL=postgresql://cursorpm:cursorpm@localhost:5432/cursorpm
REDIS_URL=redis://localhost:6379/0

# --- Concurrency / cost guardrails ---
CONCURRENCY_CAP=3
# Per-user daily spend ceiling in USD — hard stop enforced in app.
DAILY_COST_CAP_USD=10
# Claude pricing constants (USD per 1K tokens) for cost estimation. Optional overrides.
COST_PER_1K_IN=0.015
COST_PER_1K_OUT=0.075

# --- App ---
# Log level for structured JSON logging (DEBUG/INFO/WARNING/ERROR).
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins (the Vercel/Next.js frontend).
CORS_ORIGINS=http://localhost:3000
