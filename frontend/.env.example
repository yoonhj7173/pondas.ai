# Frontend env (public NEXT_PUBLIC_* are exposed to the browser). Copy to .env.local.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Stripe Embedded Checkout (billing D46). Sandbox pk_test first; swap to live later.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Analytics (loaded only after cookie consent). Unset = no analytics, no banner.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_AMPLITUDE_KEY=
